{
  "manifest_version": 3,
  "name": "Vilify",
  "version": "0.6.52",
  "description": "Minimal YouTube omnibar scaffold",
  "content_scripts": [
    {
      "matches": ["*://youtube.com/*", "*://*.youtube.com/*"],
      "js": ["dist/data-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://youtube.com/*", "*://*.youtube.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_start"
    }
  ]
}
